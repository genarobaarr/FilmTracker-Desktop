<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #121212;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.src.filmtracker.controllers.ShowDetailController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20.0" style="-fx-background-color: #000000;" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="← VOLVER" />
            <Label fx:id="headerTitle" text="Detalle de Serie" textFill="WHITE">
               <font><Font name="System Bold" size="20.0" /></font>
            </Label>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <Button mnemonicParsing="false" onAction="#handleMinimize" style="-fx-background-color: transparent; -fx-cursor: hand;" text="—" textFill="WHITE">
               <font><Font name="System Bold" size="16.0" /></font>
            </Button>
            <Button mnemonicParsing="false" onAction="#handleClose" style="-fx-background-color: transparent; -fx-cursor: hand;" text="X" textFill="WHITE">
               <font><Font name="System Bold" size="16.0" /></font>
               <HBox.margin><Insets right="15.0" /></HBox.margin>
            </Button>
         </children>
         <padding><Insets left="30.0" /></padding>
      </HBox>
   </top>
   <center>
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-control-inner-background: transparent;" vbarPolicy="ALWAYS">
         <content>
            <VBox fx:id="mainContainer" spacing="30.0">
               <children>
                  <HBox spacing="40.0">
                     <children>
                        <ImageView fx:id="posterDetail" fitHeight="500.0" fitWidth="350.0" pickOnBounds="true" preserveRatio="true" />
                        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label fx:id="titleLabel" textFill="WHITE" wrapText="true"><font><Font name="System Bold" size="48.0" /></font></Label>
                              <HBox spacing="20.0">
                                 <children>
                                    <Label fx:id="ratingLabel" textFill="#ffcc00"><font><Font name="System Bold" size="22.0" /></font></Label>
                                    <Label fx:id="statusLabel" textFill="#bbbbbb"><font><Font size="18.0" /></font></Label>
                                 </children>
                              </HBox>
                              <Label fx:id="genresLabel" textFill="#bbbbbb"><font><Font size="18.0" /></font></Label>
                              <Label text="Sinopsis" textFill="#e50914"><font><Font name="System Bold" size="20.0" /></font></Label>
                              <Label fx:id="summaryLabel" lineSpacing="5.0" textFill="WHITE" wrapText="true"><font><Font size="16.0" /></font></Label>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  
                  <VBox spacing="10.0">
                     <children>
                        <Label text="Elenco Principal" textFill="WHITE"><font><Font name="System Bold" size="22.0" /></font></Label>
                        <BorderPane>
                           <left><Button onAction="#scrollIzqCast" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 20px; -fx-cursor: hand;" text="&lt;" /></left>
                           <center>
                              <ScrollPane fx:id="scrollCast" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
                                 <content><HBox fx:id="castContainer" spacing="20.0"><padding><Insets left="10.0" right="10.0" /></padding></HBox></content>
                              </ScrollPane>
                           </center>
                           <right><Button onAction="#scrollDerCast" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 20px; -fx-cursor: hand;" text="&gt;" /></right>
                        </BorderPane>
                     </children>
                  </VBox>

                  <VBox spacing="10.0">
                     <children>
                        <Label text="Temporadas" textFill="WHITE"><font><Font name="System Bold" size="22.0" /></font></Label>
                        <VBox fx:id="episodesContainer" spacing="10.0" />
                     </children>
                  </VBox>

                  <VBox spacing="10.0">
                     <children>
                        <Label text="Series Similares" textFill="WHITE">
                           <font><Font name="System Bold" size="22.0" /></font>
                        </Label>
                        <VBox fx:id="similarShowsSection" minHeight="200.0" />
                     </children>
                  </VBox>
               </children>
               <padding><Insets bottom="50.0" left="50.0" right="50.0" top="30.0" /></padding>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>