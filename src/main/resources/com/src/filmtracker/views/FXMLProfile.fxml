<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #121212;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.src.filmtracker.controllers.ProfileController">
   <top>
      <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="← VOLVER" BorderPane.alignment="TOP_LEFT">
         <BorderPane.margin><Insets left="20.0" top="20.0" /></BorderPane.margin>
      </Button>
   </top>
   <center>
      <VBox alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <ImageView fx:id="avatarView" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(three-pass-box, rgba(229,9,20,0.4), 10, 0, 0, 0);" />
            <Label fx:id="nameLabel" text="Nombre de Usuario" textFill="WHITE">
               <font><Font name="System Bold" size="32.0" /></font>
            </Label>
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label text="Correo Electrónico" textFill="#888888">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Label>
                  <Label fx:id="emailLabel" text="correo@ejemplo.com" textFill="WHITE">
                     <font><Font size="18.0" /></font>
                  </Label>
               </children>
            </VBox>
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label text="Rol de Usuario" textFill="#888888">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Label>
                  <Label fx:id="roleLabel" text="USER" textFill="WHITE">
                     <font><Font name="System Bold" size="16.0" /></font>
                  </Label>
               </children>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>