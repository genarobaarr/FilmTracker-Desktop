<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #121212;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.src.filmtracker.controllers.ProfileController">
   <top>
      <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="← VOLVER" BorderPane.alignment="TOP_LEFT">
         <BorderPane.margin><Insets left="20.0" top="20.0" /></BorderPane.margin>
      </Button>
   </top>
   <center>
        <VBox alignment="CENTER" spacing="15.0" BorderPane.alignment="CENTER">
            <children>
                <ImageView fx:id="avatarView" fitHeight="120.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" />
                <VBox alignment="CENTER" spacing="5.0">
                    <Label fx:id="nameLabel" textFill="WHITE"><font><Font name="System Bold" size="28.0" /></font></Label>
                    <Label fx:id="usernameLabel" textFill="#e50914"><font><Font size="16.0" /></font></Label>
                </VBox>
                <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #1e1e1e; -fx-padding: 20; -fx-background-radius: 10;" maxWidth="400.0">
                    <children>
                        <Label text="Email" textFill="#888888"><font><Font name="System Bold" size="10.0" /></font></Label>
                        <Label fx:id="emailLabel" textFill="WHITE"><font><Font size="16.0" /></font></Label>
                        <Label text="Rol" textFill="#888888"><font><Font name="System Bold" size="10.0" /></font></Label>
                        <Label fx:id="roleLabel" textFill="WHITE"><font><Font size="16.0" /></font></Label>
                    </children>
                </VBox>
                <Label fx:id="dateLabel" textFill="#555555"><font><Font size="12.0" /></font></Label>
            </children>
        </VBox>
    </center>
</BorderPane>