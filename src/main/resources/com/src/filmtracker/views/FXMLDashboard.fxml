<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #121212;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.src.filmtracker.controllers.DashboardController">
   
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="15.0" style="-fx-background-color: #000000;" BorderPane.alignment="CENTER">
        <children>
           <TextField fx:id="searchField" onAction="#handleSearch" prefWidth="400.0" promptText="Buscar series..." style="-fx-background-color: #222222; -fx-text-fill: white; -fx-prompt-text-fill: #888888; -fx-background-radius: 15;">
              <HBox.margin><Insets left="20.0" /></HBox.margin>
           </TextField>
           <Button onAction="#handleSearch" style="-fx-background-color: transparent; -fx-cursor: hand;" text="🔍" textFill="WHITE">
              <font><Font size="16.0" /></font>
           </Button>

           <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />
           
           <MenuButton fx:id="profileMenu" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand;" text="👤" textFill="WHITE">
                <items>
                  <MenuItem mnemonicParsing="false" onAction="#handleVerPerfil" text="Ver Perfil" />
                  <MenuItem mnemonicParsing="false" onAction="#handleLogout" text="Cerrar Sesión" />
                </items>
                <font>
                  <Font size="18.0" />
                </font>
                <HBox.margin>
                  <Insets right="10.0" />
                </HBox.margin>
           </MenuButton>

           <Button mnemonicParsing="false" onAction="#handleMinimize" style="-fx-background-color: transparent; -fx-cursor: hand;" text="—" textFill="WHITE">
              <font><Font name="System Bold" size="16.0" /></font>
           </Button>
           <Button mnemonicParsing="false" onAction="#handleClose" style="-fx-background-color: transparent; -fx-cursor: hand;" text="X" textFill="WHITE">
              <font><Font name="System Bold" size="16.0" /></font>
              <HBox.margin><Insets right="15.0" /></HBox.margin>
           </Button>
        </children>
     </HBox>
   </top>

   <center>
      <VBox spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="FilmTracker" textFill="WHITE">
               <font><Font name="System Bold" size="28.0" /></font>
               <VBox.margin><Insets left="20.0" top="10.0" /></VBox.margin>
            </Label>
            
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-control-inner-background: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="20.0">
                     <children>
                         
                        <VBox fx:id="resultadosContainer" managed="false" spacing="5.0" visible="false">
                            <Label fx:id="labelResultados" text="Resultados de búsqueda" textFill="WHITE">
                               <font><Font name="System Bold" size="18.0" /></font>
                            </Label>
                            <BorderPane>
                               <left>
                                  <Button text="&lt;" onAction="#scrollIzqResultados" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 20px; -fx-cursor: hand;" BorderPane.alignment="CENTER" />
                               </left>
                               <center>
                                  <ScrollPane fx:id="scrollResultados" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
                                      <content>
                                          <HBox fx:id="carruselResultados" spacing="15.0">
                                             <padding><Insets left="10.0" right="10.0"/></padding>
                                          </HBox>
                                      </content>
                                  </ScrollPane>
                               </center>
                               <right>
                                  <Button text="&gt;" onAction="#scrollDerResultados" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 20px; -fx-cursor: hand;" BorderPane.alignment="CENTER" />
                               </right>
                            </BorderPane>
                         </VBox>
                         
                        <VBox spacing="5.0">
                           <Label text="Series Destacadas" textFill="WHITE">
                              <font><Font name="System Bold" size="18.0" /></font>
                           </Label>
                           <BorderPane>
                              <left>
                                 <Button text="&lt;" onAction="#scrollIzqDestacados" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 20px; -fx-cursor: hand;" BorderPane.alignment="CENTER" />
                              </left>
                              <center>
                                 <ScrollPane fx:id="scrollDestacados" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
                                     <content>
                                         <HBox fx:id="carruselDestacados" spacing="15.0"><padding><Insets left="10.0" right="10.0"/></padding></HBox>
                                     </content>
                                 </ScrollPane>
                              </center>
                              <right>
                                 <Button text="&gt;" onAction="#scrollDerDestacados" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 20px; -fx-cursor: hand;" BorderPane.alignment="CENTER" />
                              </right>
                           </BorderPane>
                        </VBox>

                        <VBox spacing="5.0">
                           <Label text="Mejor Puntuadas" textFill="WHITE">
                              <font><Font name="System Bold" size="18.0" /></font>
                           </Label>
                           <BorderPane>
                              <left>
                                 <Button text="&lt;" onAction="#scrollIzqMejorPuntuadas" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 20px; -fx-cursor: hand;" BorderPane.alignment="CENTER" />
                              </left>
                              <center>
                                 <ScrollPane fx:id="scrollMejorPuntuadas" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
                                     <content>
                                         <HBox fx:id="carruselMejorPuntuadas" spacing="15.0"><padding><Insets left="10.0" right="10.0"/></padding></HBox>
                                     </content>
                                 </ScrollPane>
                              </center>
                              <right>
                                 <Button text="&gt;" onAction="#scrollDerMejorPuntuadas" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 20px; -fx-cursor: hand;" BorderPane.alignment="CENTER" />
                              </right>
                           </BorderPane>
                        </VBox>

                        <VBox spacing="5.0">
                           <Label text="Series Nuevas" textFill="WHITE">
                              <font><Font name="System Bold" size="18.0" /></font>
                           </Label>
                           <BorderPane>
                              <left>
                                 <Button text="&lt;" onAction="#scrollIzqRecientes" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 20px; -fx-cursor: hand;" BorderPane.alignment="CENTER" />
                              </left>
                              <center>
                                 <ScrollPane fx:id="scrollRecientes" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
                                     <content>
                                         <HBox fx:id="carruselRecientes" spacing="15.0"><padding><Insets left="10.0" right="10.0"/></padding></HBox>
                                     </content>
                                 </ScrollPane>
                              </center>
                              <right>
                                 <Button text="&gt;" onAction="#scrollDerRecientes" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 20px; -fx-cursor: hand;" BorderPane.alignment="CENTER" />
                              </right>
                           </BorderPane>
                        </VBox>

                        <VBox spacing="5.0">
                           <Label text="Series Para Maratonear" textFill="WHITE">
                              <font><Font name="System Bold" size="18.0" /></font>
                           </Label>
                           <BorderPane>
                              <left>
                                 <Button text="&lt;" onAction="#scrollIzqTerminadas" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 20px; -fx-cursor: hand;" BorderPane.alignment="CENTER" />
                              </left>
                              <center>
                                 <ScrollPane fx:id="scrollTerminadas" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
                                     <content>
                                         <HBox fx:id="carruselTerminadas" spacing="15.0"><padding><Insets left="10.0" right="10.0"/></padding></HBox>
                                     </content>
                                 </ScrollPane>
                              </center>
                              <right>
                                 <Button text="&gt;" onAction="#scrollDerTerminadas" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-font-size: 20px; -fx-cursor: hand;" BorderPane.alignment="CENTER" />
                              </right>
                           </BorderPane>
                        </VBox>

                     </children>
                     <padding>
                        <Insets bottom="40.0" left="20.0" right="20.0" />
                     </padding>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
</BorderPane>